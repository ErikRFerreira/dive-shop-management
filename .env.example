# Environment variables for local development
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Auth.js secret used to encrypt and sign JWT sessions.
AUTH_SECRET="replace-with-a-random-secret"

# Shared local-only password assigned to development users by the seed script.
SEED_USER_PASSWORD="replace-with-a-local-development-password"

# Optional email-only seed account selector for `next dev`; keep disabled by default.
ENABLE_DEV_ACCOUNT_SELECTOR="false"
