generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER_SERVICE
  ADMIN
  MANAGER
  INSTRUCTOR
}

enum BookingStatus {
  DRAFT
  PENDING_APPROVAL
  NEEDS_MORE_INFO
  APPROVED
  SCHEDULED
  CANCELLED
}

enum ActivityType {
  FUN_DIVE
  DISCOVER_SCUBA_DIVING
  OPEN_WATER_COURSE
  ADVANCED_OPEN_WATER_COURSE
  RESCUE_DIVER_COURSE
  DIVEMASTER
  SPECIALTY_COURSE
  SCUBA_REVIEW
  SNORKELING
  OTHER
}

enum BookingSource {
  WECHAT
  WHATSAPP
  PHONE
  EMAIL
  WALK_IN
  REFERRAL
  INSTRUCTOR
  OTHER
}

enum PreferredLanguage {
  ENGLISH
  CHINESE
  OTHER
}

enum BookingCustomerRole {
  PRIMARY_CONTACT
  PARTICIPANT
}

enum DepositStatus {
  UNKNOWN
  PENDING
  PAID
  PARTIALLY_PAID
  WAIVED
  REFUNDED
}

enum Currency {
  PESOS
  YUAN
  EURO
  DOLLAR
  OTHER
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  role            UserRole
  isActive        Boolean          @default(true)
  createdBookings BookingRequest[] @relation("BookingCreatedBy")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([role])
  @@index([isActive])
}

model BookingRequest {
  id             String          @id @default(cuid())
  status         BookingStatus   @default(DRAFT)
  activityType   ActivityType?
  specialtyCourse String?
  source         BookingSource?
  requestedDate  DateTime?       @db.Date
  requestedTime  String?
  numberOfPeople Int?
  referrerName   String?
  startAt        DateTime?
  endAt          DateTime?
  notes          String?         @db.Text
  internalNotes  String?         @db.Text
  createdById    String
  createdBy      User            @relation("BookingCreatedBy", fields: [createdById], references: [id])
  customers      BookingCustomer[]
  deposits       Deposit[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status])
  @@index([createdById])
  @@index([requestedDate])
  @@index([startAt])
}

model Customer {
  id                String             @id @default(cuid())
  fullName          String?
  firstName         String?
  lastName          String?
  chineseName       String?
  weChatId          String?
  whatsAppNumber    String?
  email             String?
  phone             String?
  hotel             String?
  preferredLanguage PreferredLanguage?
  notes             String?            @db.Text
  bookings          BookingCustomer[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([email])
  @@index([phone])
}

model BookingCustomer {
  bookingRequestId   String
  customerId         String
  role               BookingCustomerRole @default(PARTICIPANT)
  certificationAgency String?
  certificationLevel  String?
  lastDiveAt          DateTime?
  equipmentNeeded     Boolean?
  heightCm            Int?
  weightKg            Decimal?          @db.Decimal(5, 2)
  shoeSize            Decimal?          @db.Decimal(4, 1)
  maskNotes           String?           @db.Text
  divesLogged         Int?
  bookingRequest     BookingRequest     @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  customer           Customer           @relation(fields: [customerId], references: [id])
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@id([bookingRequestId, customerId])
  @@index([customerId])
}

model Deposit {
  id               String          @id @default(cuid())
  bookingRequestId String
  amount           Decimal?        @db.Decimal(10, 2)
  status           DepositStatus   @default(PENDING)
  currency         String?
  paidTo           String?
  paymentMethod    String?
  dueAt            DateTime?
  paidAt           DateTime?
  notes            String?         @db.Text
  bookingRequest   BookingRequest  @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([bookingRequestId])
  @@index([status])
}
